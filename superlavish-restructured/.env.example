# ──────────────────────────────────────────────────────────────────────────────
# SuperLavish — Environment Variables
# Copy to .env and fill in real values. NEVER commit .env to git.
# ──────────────────────────────────────────────────────────────────────────────

# ── Frontend ──────────────────────────────────────────────────────────────────
REACT_APP_API_URL=http://localhost:8080/api

# ── Backend (shared) ──────────────────────────────────────────────────────────
JWT_SECRET=replace_with_secure_256bit_random_string
JWT_EXPIRATION=86400000
JWT_REFRESH_EXPIRATION=604800000

# ── Database ──────────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your_secure_password

# ── AWS ──────────────────────────────────────────────────────────────────────
AWS_REGION=ap-southeast-2
AWS_ACCOUNT_ID=123456789012
EKS_CLUSTER_NAME=superlavish-prod

# ── ECR ───────────────────────────────────────────────────────────────────────
ECR_REGISTRY=${AWS_ACCOUNT_ID}.dkr.ecr.${AWS_REGION}.amazonaws.com

# ── Terraform ─────────────────────────────────────────────────────────────────
TF_VAR_db_password=your_rds_password

# ── Jenkins ───────────────────────────────────────────────────────────────────
# Configure these as Jenkins credentials, not environment variables
# SONAR_TOKEN=your_sonarqube_token
# SLACK_WEBHOOK=https://hooks.slack.com/services/xxx

# ── CORS ──────────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,https://superlavish.com
