# ──────────────────────────────────────────────────────────────────────────────
# Terraform
# ──────────────────────────────────────────────────────────────────────────────
**/.terraform/
**/.terraform.lock.hcl
*.tfstate
*.tfstate.*
*.tfplan
crash.log
crash.*.log
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Do NOT commit tfvars with real secrets — keep *.example versions only
*.auto.tfvars
secrets.tfvars

# ──────────────────────────────────────────────────────────────────────────────
# Java / Maven
# ──────────────────────────────────────────────────────────────────────────────
backend/**/target/
backend/**/.mvn/
backend/**/dependency-reduced-pom.xml
*.class
*.jar
!**/.mvn/wrapper/maven-wrapper.jar

# ──────────────────────────────────────────────────────────────────────────────
# Node / Frontend
# ──────────────────────────────────────────────────────────────────────────────
frontend/node_modules/
frontend/build/
frontend/dist/
frontend/.next/
frontend/coverage/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ──────────────────────────────────────────────────────────────────────────────
# Environment / Secrets
# ──────────────────────────────────────────────────────────────────────────────
.env
.env.local
.env.*.local
*.pem
*.key
*.p12
kubeconfig
.aws/

# ──────────────────────────────────────────────────────────────────────────────
# IDE
# ──────────────────────────────────────────────────────────────────────────────
.idea/
.vscode/
*.iml
*.ipr
*.iws
.project
.classpath
.settings/

